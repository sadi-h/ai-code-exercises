@code JsDoc
/**
 * Merges two collections of tasks from local and remote sources into a single
 * synchronized task set while determining which tasks need to be created or
 * updated in each source.
 *
 * The merge process performs conflict resolution for tasks that exist in both
 * collections by delegating to {@link resolveTaskConflict}. It also identifies:
 *
 * - Tasks that only exist locally and should be created remotely
 * - Tasks that only exist remotely and should be created locally
 * - Tasks that exist in both sources but require updates after conflict resolution
 *
 * Conflict resolution rules include:
 * - Most recently updated task fields take precedence
 * - Completed tasks (`TaskStatus.DONE`) always win over incomplete states
 * - Tags are merged using a union operation
 * - Synchronization update flags are generated for each source as needed
 *
 * @function mergeTaskLists
 *
 * @param {Object.<string, Object>} localTasks
 * A map of locally stored task objects keyed by task ID.
 *
 * @param {Object.<string, Object>} remoteTasks
 * A map of remotely stored task objects keyed by task ID.
 *
 * @param {string} localTasks[].id
 * Unique identifier for the task.
 *
 * @param {string} localTasks[].title
 * Human-readable task title.
 *
 * @param {string} [localTasks[].description]
 * Optional task description or notes.
 *
 * @param {string} localTasks[].status
 * Current task status value.
 *
 * @param {string|number} [localTasks[].priority]
 * Task priority level.
 *
 * @param {string|null} [localTasks[].dueDate]
 * Optional due date in a parseable date format.
 *
 * @param {string[]} localTasks[].tags
 * Array of task tags or categories.
 *
 * @param {string} localTasks[].updatedAt
 * ISO timestamp representing the last modification time.
 *
 * @param {string|null} [localTasks[].completedAt]
 * ISO timestamp indicating when the task was completed.
 *
 * @returns {{
 *   mergedTasks: Object.<string, Object>,
 *   toCreateRemote: Object.<string, Object>,
 *   toUpdateRemote: Object.<string, Object>,
 *   toCreateLocal: Object.<string, Object>,
 *   toUpdateLocal: Object.<string, Object>
 * }}
 * An object containing the merged task state and synchronization operations.
 *
 * @returns {Object.<string, Object>} returns.mergedTasks
 * Fully merged collection of all tasks after conflict resolution.
 *
 * @returns {Object.<string, Object>} returns.toCreateRemote
 * Tasks that exist locally but must be created in the remote source.
 *
 * @returns {Object.<string, Object>} returns.toUpdateRemote
 * Tasks that already exist remotely but require updates.
 *
 * @returns {Object.<string, Object>} returns.toCreateLocal
 * Tasks that exist remotely but must be created locally.
 *
 * @returns {Object.<string, Object>} returns.toUpdateLocal
 * Tasks that already exist locally but require updates.
 *
 * @throws {TypeError}
 * Thrown if either `localTasks` or `remoteTasks` is `null`, `undefined`,
 * or not a valid object.
 *
 * @throws {RangeError}
 * May be thrown indirectly if task date fields contain invalid date values
 * that cannot be parsed by the `Date` constructor during conflict resolution.
 *
 * @example
 * const localTasks = {
 *   "task-1": {
 *     id: "task-1",
 *     title: "Buy groceries",
 *     status: "IN_PROGRESS",
 *     tags: ["shopping"],
 *     updatedAt: "2026-05-20T10:00:00Z"
 *   }
 * };
 *
 * const remoteTasks = {
 *   "task-2": {
 *     id: "task-2",
 *     title: "Finish report",
 *     status: "DONE",
 *     tags: ["work"],
 *     updatedAt: "2026-05-21T08:30:00Z"
 *   }
 * };
 *
 * const result = mergeTaskLists(localTasks, remoteTasks);
 *
 * console.log(result.mergedTasks);
 * console.log(result.toCreateRemote);
 * console.log(result.toCreateLocal);
 *
 * @example
 * // Resolving conflicts between matching task IDs
 * const localTasks = {
 *   "task-1": {
 *     id: "task-1",
 *     title: "Write documentation",
 *     status: "IN_PROGRESS",
 *     tags: ["docs"],
 *     updatedAt: "2026-05-20T09:00:00Z"
 *   }
 * };
 *
 * const remoteTasks = {
 *   "task-1": {
 *     id: "task-1",
 *     title: "Write API documentation",
 *     status: "DONE",
 *     tags: ["docs", "api"],
 *     updatedAt: "2026-05-21T09:00:00Z"
 *   }
 * };
 *
 * const result = mergeTaskLists(localTasks, remoteTasks);
 *
 * // Remote version wins due to newer timestamp and completed status
 * console.log(result.mergedTasks["task-1"]);
 *
 * @note
 * Task IDs are assumed to be unique across both collections.
 *
 * @note
 * Tags are merged using a set union operation, preventing duplicate tags.
 *
 * @note
 * This function does not mutate the original task collection objects directly,
 * though merged task references may still share nested object references if
 * present inside task payloads.
 *
 * @note
 * Timestamp comparisons rely on the JavaScript `Date` constructor. Invalid or
 * inconsistent timestamp formats may produce unreliable merge behavior.
 *
 * @note
 * When both task versions have the same `updatedAt` timestamp, the local task
 * version is treated as authoritative for non-status fields.
 */
@end
