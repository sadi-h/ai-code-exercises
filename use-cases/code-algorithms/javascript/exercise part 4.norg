// models.js
const TaskStatus = {
  TODO: 'todo',
  IN_PROGRESS: 'in_progress',
  REVIEW: 'review',
  DONE: 'done',
  ABANDONED: 'abandoned',
  PRIORITY: 'priority'
};

class Task {
.... rest of code

isAbandoned() {
    if (!this.status) {
      return false;
    }
    return this.status === TaskStatus.ABANDONED;
  }
}


