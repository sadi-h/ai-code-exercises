                $ref: "#/components/schemas/ErrorResponse"

              examples:
                metadataNotFound:
                  summary: Metadata does not exist
                  value:
                    error: "metadata not found"

                fileNotFound:
                  summary: Audio file missing
                  value:
                    error: "No such file or directory"

        "416":
          description: Requested range is invalid or outside file bounds

          headers:
            Content-Range:
