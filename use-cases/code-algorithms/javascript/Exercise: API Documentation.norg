            Example:
              bytes=0-1048575
          schema:
            type: string
            pattern: "^bytes=\\d+-\\d+$"
          example: bytes=0-1048575

      responses:
        "206":
          description: Partial audio content successfully streamed

          headers:
            Content-Type:
              description: MIME type of the streamed audio
              schema:
                type: string
                example: audio/mpeg

            Accept-Ranges:
              description: Indicates byte-range support
              schema:
                type: string
                example: bytes

            Content-Range:
              description: Returned byte range
              schema:
