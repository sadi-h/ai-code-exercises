
                        $ _The original API endpoint code I chose to document_


@code rust
    async fn stream_audio(
        _claims: Access,
        Path(metadata_id): Path<Uuid>,
        headers: HeaderMap,
    ) -> Result<impl IntoResponse, ApiError> {
        let metadata = db_client()?
            .get_audio_metadata(metadata_id)
            .await?
            .ok_or_else(|| ApiError::not_found("metadata not found"))?;

        // directory triversal not possible since the file_name was cleaned when metadata was being added
        // also, the use of metadata_id to get chunks instead of accepting file paths mitigates risk
        let path = std::path::Path::new(&metadata.file_name);

        let mut file = match fs::File::open(&path).await {
            Ok(file) => file,
            Err(e) => return Err(ApiError::not_found(e.to_string())),
        };

        let file_size = match file.metadata().await {
            Ok(metadata) => metadata.len(),
            Err(e) => return Err(ApiError::internal(e.to_string())),
        };

        let range = if let Some(range_header) = headers.get(axum::http::header::RANGE) {
            match range_header.to_str() {
                Ok(value) => match parse_range_header(value, file_size) {
                    Some(range) => range,
                    None => {
                        let mut resp =
                            ApiError::new(status::StatusCode::RANGE_NOT_SATISFIABLE, "Invalid range")
                                .into_response();
                        resp.headers_mut().insert(
                            http::header::CONTENT_RANGE,
                            http::HeaderValue::from_str(&format!("bytes */{file_size}")).unwrap(),
                        );
                        return Ok(resp);
                    }
                },
                Err(e) => return Err(ApiError::bad_request(e.to_string())),
            }
        } else {
            return Err(ApiError::bad_request("Range header required"));
        };

        let ops::Range { start, end } = range;

      let length = (end - start) + 1;

      if length > MAX_RANGE_SIZE {
          return Err(ApiError::bad_request(format!(
              "Range error: range can not exceed {MAX_RANGE_SIZE} bytes"
          )));
      }

      if file.seek(std::io::SeekFrom::Start(start)).await.is_err() {
          return Err(ApiError::new(
              status::StatusCode::RANGE_NOT_SATISFIABLE,
              "Seek error",
          ));
      }

      let content_range = format!("bytes {start}-{end}/{file_size}");

      let stream = stream_chunk(file, length);

      let resp = axum::response::Response::builder()
          .status(status::StatusCode::PARTIAL_CONTENT)
          .header(http::header::CONTENT_TYPE, "audio/mpeg")
          .header(http::header::ACCEPT_RANGES, "bytes")
          .header(http::header::CONTENT_RANGE, content_range)
          .header(http::header::CONTENT_LENGTH, length)
          .body(Body::from_stream(stream))
          .unwrap();
      Ok(resp)
  }
@end


