* In this part, use the "Prompt 3: Mapping Data Flow and State Management" prompt to understand how data flows through the application when a task is marked as complete.

  $ _Identify the entry points and components involved when marking a task as complete_
  ~ {* /ai-code-exercises/use-cases/code-algorithms/javascript/TaskManager/cli.js}[cli.js] - This takes user input from terminal. In this case, takes status option that is used to mark the task as complete
  ~ {* /ai-code-exercises/use-cases/code-algorithms/javascript/TaskManager/app.js}[app.js] - This contains the `TaskManager` class that has a method `updateTaskStatus` that calls  `markAsDone` method on the task instance.

  $ _Find code that handles state changes for task completion_
    - the code responsible for marking a task as complete is:

      @code JavaScript
      // app.js
      const { Task, TaskPriority, TaskStatus } = require('./models');
      const { TaskStorage } = require('./storage');

      class TaskManager {
        //... rest of code 

        updateTaskStatus(taskId, newStatusValue) {
          if (newStatusValue === TaskStatus.DONE) {
            const task = this.storage.getTask(taskId);
            if (task) {
              task.markAsDone();
              this.storage.save();
              return true;
            }
            return false;
          } else {
            return this.storage.updateTask(taskId, { status: newStatusValue });
          }
        }

      //... rest of code 
      }

      module.exports = { TaskManager };
      @end

      @code JavaScript
      // cli.js
      const { program } = require('commander');
      const { TaskManager } = require('./app');
      const { TaskStatus, TaskPriority } = require('./models');

      //... rest of code

      program
        .command('status <task_id> <status>')
        .description('Update task status')
        .action((taskId, status) => {
          if (taskManager.updateTaskStatus(taskId, status)) {
            console.log(`Updated task status to ${status}`);
          } else {
            console.log('Failed to update task status. Task not found.');
          }
        });

      //... rest of code
      @end





